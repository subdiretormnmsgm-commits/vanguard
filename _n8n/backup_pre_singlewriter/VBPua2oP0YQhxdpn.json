                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({origem:\"W-3\",tipo:\"push\",dados:{branch:$(\"Extrair Dados do Push\").item.json.branch,sha:$(\"Extrair Dados do Push\").item.json.sha},timestamp:new Date().toISOString()}) }}",
                                         "ignoreResponseCode":  true,
                                         "options":  {
                                                         "timeout":  5000
                                                     }
                                     }
                  }
