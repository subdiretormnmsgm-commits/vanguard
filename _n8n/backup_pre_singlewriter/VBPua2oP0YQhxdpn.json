                      "id":  "webhook-github",
                      "name":  "Webhook GitHub Push",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  2,
                      "position":  [
                                       240,
                                       300
                                   ],
                      "parameters":  {
                                         "httpMethod":  "POST",
                                         "path":  "github-push-vanguard",
                                         "responseMode":  "onReceived",
                                         "options":  {

                                                     }
                                     },
                      "webhookId":  "2a99ecc6-a8df-4dfa-aa9a-59f036cecb87"
                  },
                  {
                      "id":  "code-validar-hmac",
                      "name":  "Validar Origem GitHub",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       460,
                                       300
                                   ],
                      "parameters":  {
                                         "jsCode":  "const headers=$input.item.json.headers||{};const sig=(headers[\"x-hub-signature-256\"]||headers[\"x-hub-signature\"]||\"\");if(!sig){return [{json:{erro:\"Sem assinatura GitHub\",valido:false}}];}return [$input.item];"
                                     }
                  },
                  {
                      "id":  "code-extrair",
                      "name":  "Extrair Dados do Push",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       680,
                                       300
                                   ],
                      "parameters":  {
                                         "jsCode":  "const body=$input.item.json.body||$input.item.json;const commits=body.commits||[];const pusher=(body.pusher\u0026\u0026body.pusher.name)||\"desconhecido\";const repo=(body.repository\u0026\u0026body.repository.name)||\"vanguard\";const branch=(body.ref||\"\").replace(\"refs/heads/\",\"\");const ultimoCommit=commits.length\u003e0?commits[commits.length-1]:null;const msg=ultimoCommit?ultimoCommit.message.split(\"\\n\")[0]:\"(sem mensagem)\";const ts=ultimoCommit?ultimoCommit.timestamp:\"\";const tsLabel=ts?new Date(ts).toLocaleString(\"pt-BR\",{timeZone:\"America/Sao_Paulo\",day:\"2-digit\",month:\"2-digit\",year:\"numeric\",hour:\"2-digit\",minute:\"2-digit\"}):new Date().toLocaleString(\"pt-BR\",{timeZone:\"America/Sao_Paulo\",day:\"2-digit\",month:\"2-digit\",year:\"numeric\",hour:\"2-digit\",minute:\"2-digit\"});const texto=\"Novo commit no \"+repo+\"\\n\"+msg+\"\\n\"+pusher+\" . \"+tsLabel;return [{json:{texto:texto,pusher:pusher,repo:repo,branch:branch,msg:msg,ts:tsLabel,sha:ultimoCommit?ultimoCommit.id:\"\",totalCommits:commits.length}}];"
                                     }
                  },
                  {
                      "id":  "telegram-commit",
                      "name":  "Telegram -- Notificar Commit",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       900,
                                       300
                                   ],
                      "continueOnFail":  true,
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "={{ \u0027https://api.telegram.org/bot\u0027 + $env.TELEGRAM_BOT_TOKEN + \u0027/sendMessage\u0027 }}",
                                         "sendBody":  true,
                                         "contentType":  "json",
                                         "bodyParameters":  {
                                                                "parameters":  [
                                                                                   {
                                                                                       "name":  "chat_id",
                                                                                       "value":  "8895733647"
                                                                                   },
                                                                                   {
                                                                                       "name":  "text",
                                                                                       "value":  "={{ $json.texto }}"
                                                                                   }
                                                                               ]
                                                            }
                                     }
                  },
                  {
                      "id":  "code-notion-w3",
                      "name":  "Preparar Notion Body",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1120,
                                       300
                                   ],
                      "parameters":  {
                                         "jsCode":  "const item = $(\"Extrair Dados do Push\").item.json;\nconst tsStr = new Date().toISOString().replace(\"T\",\" \").slice(0,16) + \" UTC\";\nconst msg = String(item.msg || \"\").replace(/\\n/g, \" \").slice(0, 300);\nconst repo = String(item.repo || \"?\");\nconst branch = String(item.branch || \"?\");\nconst pusher = String(item.pusher || \"?\");\nconst ts = String(item.ts || tsStr);\n\nconst blocos = [\n    { object:\"block\", type:\"divider\", divider:{} },\n    { object:\"block\", type:\"callout\", callout:{ rich_text:[{type:\"text\",text:{content:\"📝 Commit · \"+tsStr},annotations:{bold:true}}], icon:{type:\"emoji\",emoji:\"📝\"}, color:\"gray_background\" } },\n    { object:\"block\", type:\"quote\", quote:{ rich_text:[{type:\"text\",text:{content:msg}}] } },\n    { object:\"block\", type:\"bulleted_list_item\", bulleted_list_item:{ rich_text:[{type:\"text\",text:{content:\"📁 \"+repo+\" [\"+branch+\"]\"}}] } },\n    { object:\"block\", type:\"bulleted_list_item\", bulleted_list_item:{ rich_text:[{type:\"text\",text:{content:\"👤 \"+pusher+\" · \"+ts}}] } }\n];\n\nreturn [{ json: { children: blocos } }];"
                                     }
                  },
                  {
                      "id":  "notion-wip-w3",
                      "name":  "Notion -- Append WIP Board",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       1340,
                                       300
                                   ],
                      "continueOnFail":  true,
                      "parameters":  {
                                         "method":  "PATCH",
                                         "url":  "={{ \u0027https://api.notion.com/v1/blocks/\u0027 + $env.NOTION_WIP_PAGE_ID + \u0027/children\u0027 }}",
                                         "sendHeaders":  true,
                                         "specifyHeaders":  "keypair",
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "Authorization",
                                                                                         "value":  "={{ \u0027Bearer \u0027 + $env.NOTION_API_TOKEN }}"
                                                                                     },
                                                                                     {
                                                                                         "name":  "Notion-Version",
                                                                                         "value":  "2022-06-28"
                                                                                     },
                                                                                     {
                                                                                         "name":  "Content-Type",
                                                                                         "value":  "application/json"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "options":  {
                                                         "timeout":  15000
                                                     },
                                         "ignoreResponseCode":  true,
                                         "jsonBody":  "={{ JSON.stringify({ children: $(\"Preparar Notion Body\").item.json.children }) }}"
                                     }
                  },
