                  {
                      "parameters":  {
                                         "jsCode":  "const item = $(\u0027Detectar Periodo\u0027).item.json;\nconst tsStr = new Date().toISOString().replace(\u0027T\u0027,\u0027 \u0027).slice(0,16) + \u0027 UTC\u0027;\nconst periodo = String(item.periodo || \u0027dia\u0027);\nconst statusText = String(item.statusProjetos || \u0027\u0027);\nconst NL = String.fromCharCode(10);\nconst DOT = String.fromCharCode(183);\nconst normalized = statusText.split(NL).join(DOT);\nconst projLines = normalized.split(DOT).map(l =\u003e l.trim()).filter(l =\u003e l.length \u003e 0);\n\n// Emoji e cor por período\nconst periodoEmoji = periodo === \u0027manha\u0027 ? \u0027🌅\u0027 : periodo === \u0027tarde\u0027 ? \u0027🌤️\u0027 : \u0027🌙\u0027;\nconst periodoLabel = periodo === \u0027manha\u0027 ? \u0027Bom dia\u0027 : periodo === \u0027tarde\u0027 ? \u0027Boa tarde\u0027 : \u0027Boa noite\u0027;\n\n// Adicionar emoji de semáforo por linha\nfunction semaforo(line) {\n    const l = line.toUpperCase();\n    if (l.includes(\u0027VERMELHO\u0027) || l.includes(\u0027ERROR\u0027) || l.includes(\u0027OFFLINE\u0027)) return \u0027🔴 \u0027 + line;\n    if (l.includes(\u0027AMARELO\u0027) || l.includes(\u0027ATENÇÃO\u0027) || l.includes(\u0027ATENCAO\u0027) || l.includes(\u0027CHECK\u0027)) return \u0027🟡 \u0027 + line;\n    if (l.includes(\u0027VERDE\u0027) || l.includes(\u0027OK\u0027) || l.includes(\u0027RETAINER\u0027) || l.includes(\u0027SUCCESS\u0027)) return \u0027🟢 \u0027 + line;\n    return \u0027▸ \u0027 + line;\n}\n\nconst blocos = [\n    { object:\u0027block\u0027, type:\u0027divider\u0027, divider:{} },\n    { object:\u0027block\u0027, type:\u0027callout\u0027, callout:{ rich_text:[{type:\u0027text\u0027,text:{content:periodoEmoji+\u0027 Check-in · \u0027+periodoLabel+\u0027 · \u0027+tsStr},annotations:{bold:true}}], icon:{type:\u0027emoji\u0027,emoji:\u0027📊\u0027}, color:\u0027blue_background\u0027 } }\n];\n\nif (projLines.length === 0) {\n    blocos.push({ object:\u0027block\u0027, type:\u0027bulleted_list_item\u0027, bulleted_list_item:{ rich_text:[{type:\u0027text\u0027,text:{content:statusText.slice(0,200)}}] } });\n} else {\n    projLines.forEach(line =\u003e {\n        blocos.push({ object:\u0027block\u0027, type:\u0027bulleted_list_item\u0027, bulleted_list_item:{ rich_text:[{type:\u0027text\u0027,text:{content:semaforo(line)}}] } });\n    });\n}\n\nreturn [{ json: { notionChildren: blocos } }];"
                                     },
