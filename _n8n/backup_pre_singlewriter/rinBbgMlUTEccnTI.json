                      "parameters":  {
                                         "jsCode":  "const agora = new Date();\nconst horaBR = parseInt(agora.toLocaleString(\u0027pt-BR\u0027, {timeZone: \u0027America/Sao_Paulo\u0027, hour: \u00272-digit\u0027, hour12: false}));\nconst dataBR = agora.toLocaleDateString(\u0027pt-BR\u0027, {timeZone: \u0027America/Sao_Paulo\u0027});\nlet periodo;\nif (horaBR \u003e= 5 \u0026\u0026 horaBR \u003c 12) periodo = \u0027MANHA\u0027;\nelse if (horaBR \u003e= 12 \u0026\u0026 horaBR \u003c 18) periodo = \u0027TARDE\u0027;\nelse periodo = \u0027NOITE\u0027;\nconst saudacoes = {MANHA: \u0027Bom dia, Diretor.\u0027, TARDE: \u0027Boa tarde, Diretor.\u0027, NOITE: \u0027Boa noite, Diretor.\u0027};\nlet statusProjetos = \u0027\u0027;\ntry {\n  const wipRaw = $(\u0027Ler WIP_BOARD\u0027).item.json;\n  let wip;\n  if (wipRaw \u0026\u0026 wipRaw.board) {\n    wip = wipRaw;\n  } else if (wipRaw \u0026\u0026 wipRaw.content) {\n    const decoded = Buffer.from(wipRaw.content.replace(/\\n/g, \u0027\u0027), \u0027base64\u0027).toString(\u0027utf8\u0027);\n    wip = JSON.parse(decoded.replace(/^\\uFEFF/, \u0027\u0027));\n  } else if (wipRaw \u0026\u0026 typeof wipRaw.body === \u0027string\u0027) {\n    wip = JSON.parse(wipRaw.body.replace(/^\\uFEFF/, \u0027\u0027));\n  } else {\n    wip = {};\n  }\n  const board = wip.board || {};\n  const todos = [];\n  if (board.build) todos.push(...board.build);\n  if (board.check) todos.push(...board.check);\n  if (board.retainer) todos.push(...board.retainer);\n  if (board.entregue) todos.push(...board.entregue);\n  const linhas = todos.map(function(p) {\n    const nome = p.cliente || p.id || \u0027Projeto\u0027;\n    const st = (p.status || \u0027ATIVO\u0027).split(\u0027 -- \u0027)[0];\n    return \u0027- \u0027 + nome + \u0027: \u0027 + st;\n  });\n  statusProjetos = linhas.length \u003e 0 ? linhas.join(\u0027\\n\u0027) : \u0027- (sem projetos ativos)\u0027;\n} catch (e) {\n  statusProjetos = \u0027- (ERRO: \u0027 + e.message + \u0027)\u0027;\n}\nreturn [{json: {periodo: periodo, saudacao: saudacoes[periodo], hora: horaBR, data: dataBR, timestamp: agora.toISOString(), statusProjetos: statusProjetos}}];"
