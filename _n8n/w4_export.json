                  {
                      "parameters":  {
                                         "jsCode":  "const item = $(\u0027Processar Payload\u0027).item.json;\nconst tsStr = new Date().toISOString().replace(\u0027T\u0027,\u0027 \u0027).slice(0,16)+\u0027 UTC\u0027;\nconst wipBlocos = [{object:\u0027block\u0027,type:\u0027heading_3\u0027,\n  heading_3:{rich_text:[{type:\u0027text\u0027,text:{content:\u0027Sessao \u0027+tsStr}}]}}];\n[\u0027Cliente: \u0027+(item.cliente||\u0027?\u0027),\n \u0027Principios: +\u0027+(item.principios||[]).length+\u0027 | Friccoes: +\u0027+(item.friccoes||[]).length+\u0027 | Dividas: +\u0027+(item.dividas||[]).length\n].forEach(function(l){\n  wipBlocos.push({object:\u0027block\u0027,type:\u0027bulleted_list_item\u0027,\n    bulleted_list_item:{rich_text:[{type:\u0027text\u0027,text:{content:l}}]}});\n});\nconst pendBlocos = [{object:\u0027block\u0027,type:\u0027heading_3\u0027,\n  heading_3:{rich_text:[{type:\u0027text\u0027,text:{content:\u0027Dividas \u0027+tsStr}}]}}];\nconst dividas = (item.dividas||[]).length\u003e0 ? item.dividas : [\u0027(sem dividas tecnicas)\u0027];\ndividas.forEach(function(d){\n  pendBlocos.push({object:\u0027block\u0027,type:\u0027bulleted_list_item\u0027,\n    bulleted_list_item:{rich_text:[{type:\u0027text\u0027,text:{content:String(d)}}]}});\n});\nreturn [{ json: { wipChildren: wipBlocos, pendChildren: pendBlocos } }];"
