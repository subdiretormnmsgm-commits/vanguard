                  {
                      "parameters":  {
                                         "jsCode":  "const payload = $input.item.json.body || $input.item.json;\nconst cliente = payload.cliente || \u0027GERAL\u0027;\nconst principios = payload.principios || [];\nconst friccoes = payload.friccoes || [];\nconst dividas = payload.dividas || [];\nconst documentos_mortos = payload.documentos_mortos || [];\nconst inconsistencias = payload.inconsistencias || [];\nconst ficou_no_ar = payload.ficou_no_ar || \u0027\u0027;\nconst diretor_mencionou = payload.diretor_mencionou || \u0027\u0027;\nconst data = payload.data || new Date().toLocaleDateString(\u0027pt-BR\u0027, {timeZone: \u0027America/Sao_Paulo\u0027});\nconst hora = payload.hora || new Date().toLocaleTimeString(\u0027pt-BR\u0027, {timeZone: \u0027America/Sao_Paulo\u0027, hour: \u00272-digit\u0027, minute: \u00272-digit\u0027});\nconst resumoPrincipios = principios.length \u003e 0 ? principios.map(function(p, i) { return (i+1) + \u0027. \u0027 + p; }).join(\u0027\\n\u0027) : \u0027Nenhum principio novo\u0027;\nconst resumoFriccoes = friccoes.length \u003e 0 ? friccoes.map(function(f, i) { return (i+1) + \u0027. \u0027 + f; }).join(\u0027\\n\u0027) : \u0027Nenhuma friccao\u0027;\nconst extraLinhas = [];\nif (documentos_mortos.length \u003e 0) extraLinhas.push(\u0027Docs mortos: \u0027 + documentos_mortos.join(\u0027, \u0027));\nif (inconsistencias.length \u003e 0) extraLinhas.push(\u0027Inconsistencias: \u0027 + inconsistencias.join(\u0027, \u0027));\nif (ficou_no_ar) extraLinhas.push(\u0027Ficou no ar: \u0027 + ficou_no_ar);\nif (diretor_mencionou) extraLinhas.push(\u0027Diretor mencionou: \u0027 + diretor_mencionou);\nconst extraBloco = extraLinhas.length \u003e 0 ? \u0027\\n\\n\u0027 + extraLinhas.join(\u0027\\n\u0027) : \u0027\u0027;\nconst texto = \u0027Sessao encerrada -- \u0027 + data + \u0027 \u0027 + hora + \u0027\\nCliente: \u0027 + cliente + \u0027\\n\\nPrincipios (+\u0027 + principios.length + \u0027):\\n\u0027 + resumoPrincipios + \u0027\\n\\nFriccoes (+\u0027 + friccoes.length + \u0027):\\n\u0027 + resumoFriccoes + \u0027\\n\\nDividas: \u0027 + dividas.length + extraBloco;\nreturn [{ json: { cliente: cliente, data: data, hora: hora, texto: texto, principios: principios, friccoes: friccoes, dividas: dividas, documentos_mortos: documentos_mortos, inconsistencias: inconsistencias, ficou_no_ar: ficou_no_ar, diretor_mencionou: diretor_mencionou } }];"
                                     },
