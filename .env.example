# ═══════════════════════════════════════════════════════════
# Vanguard Soberano Digital V6 — SaaS Multi-Tenant
# Copie para .env e preencha com as suas credenciais
# ═══════════════════════════════════════════════════════════

# ── Supabase (obrigatório) ───────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...         # service_role — bypassa RLS, para API Bridge
SUPABASE_JWT_SECRET=CHAVE_JWT_DO_SUPABASE  # Settings → API → JWT Secret

# ── Feature 04 V6: Stripe Billing ───────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...      # 100 leads/mês
STRIPE_PRICE_PRO=price_...          # 500 leads/mês
STRIPE_PRICE_ENTERPRISE=price_...   # 2000 leads/mês
SAAS_URL=https://seudominio.com/saas

# ── Feature 01: Auditor IA (Claude Haiku) ───────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Scraper on-demand (opcional) ────────────────────────
GOOGLE_PLACES_API_KEY=AIza...
VANGUARD_QUIZ_URL=https://seudominio.com/#quiz
SCRAPER_NICHO=advocacia
SCRAPER_CIDADE=São Paulo
SCRAPER_LIMITE=10
SCRAPER_MODO=osm

# ── n8n / Hermes ────────────────────────────────────────
N8N_HOST=n8n.seudominio.com
N8N_USER=admin
N8N_PASSWORD=SENHA_FORTE_AQUI
N8N_ENCRYPTION_KEY=CHAVE_32_CHARS_AQUI
POSTGRES_PASSWORD=SENHA_POSTGRES_AQUI
WA_VERIFY_TOKEN=TOKEN_VERIFICACAO_WA
WA_TOKEN=TOKEN_WHATSAPP_API
WA_PHONE_NUMBER_ID=ID_NUMERO_WA

# ── Feature 03: White-Label (opcional, override por cliente) ──
BRAND_NAME=VANGUARD
BRAND_TAGLINE=Forja de Ecossistemas Digitais
BRAND_PRIMARY=#00F0FF
BRAND_SECONDARY=#1A0B2E
BRAND_ACCENT=#7B2FFF
BRAND_BG=#0A0A0A
