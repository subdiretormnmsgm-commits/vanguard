{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/session_start.ps1",
            "timeout": 15,
            "statusMessage": "Carregando instrumentos de memoria do Pentalateral..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/hv1_credential_guard.ps1",
            "timeout": 5,
            "statusMessage": "Verificando HV-1 (credencial hardcoded)..."
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/file_protection_guard.ps1",
            "timeout": 5,
            "statusMessage": "P-098 -- Verificando protecao de arquivo de processo..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash|browser_navigate",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/skill_gate_guard.ps1",
            "timeout": 10,
            "statusMessage": "P-180 -- Verificando skill obrigatoria da etapa..."
          }
        ]
      },
      {
        "matcher": "browser_navigate|browser_file_upload",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/gdrive_fresh_guard.ps1",
            "timeout": 12,
            "statusMessage": "P-168/P-169 -- Verificando frescor do gdrive:vanguard (data+hora)..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/rclone_secrets_guard.ps1",
            "timeout": 5,
            "statusMessage": "P-185 -- Verificando filtro de segredos no rclone sync/copy..."
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/shell_protection_guard.ps1",
            "timeout": 5,
            "statusMessage": "P-184 -- Verificando gravacao shell em arquivo protegido..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/fechamento_checklist.ps1",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/gdrive_fresh_tracker.ps1",
            "timeout": 5,
            "statusMessage": "P-168/P-169 -- Registrando VERDE de frescor do Drive..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/p033_sync_guardian.ps1",
            "timeout": 60,
            "statusMessage": "P-033 — Verificando se sync e necessario..."
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/passo7_auto_display.ps1",
            "timeout": 15,
            "statusMessage": "PASSO7 — Verificando se e necessario exibir Embaixador..."
          }
        ]
      },
      {
        "matcher": "Skill|Read",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/skill_tracker.ps1",
            "timeout": 5,
            "statusMessage": "P-180 -- Registrando skill invocada..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/stop_checklist.ps1",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/cowork_notify.ps1",
            "timeout": 10,
            "statusMessage": "COWORK -- Notificando Cowork do encerramento da sessao..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/skill_gate_prompt.ps1",
            "timeout": 10,
            "statusMessage": "P-180 -- Detectando gatilho de etapa..."
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/nicho_role_guard.ps1",
            "timeout": 10,
            "statusMessage": "GATE DE PAPEL -- Verificando tema nicho/projecao (item 42)..."
          }
        ]
      }
    ]
  }
}