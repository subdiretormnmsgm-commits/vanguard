{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/session_start.ps1",
            "timeout": 15,
            "statusMessage": "Carregando instrumentos de memoria do Pentalateral..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/hv1_credential_guard.ps1",
            "timeout": 5,
            "statusMessage": "Verificando HV-1 (credencial hardcoded)..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/fechamento_checklist.ps1",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/p033_sync_guardian.ps1",
            "timeout": 60,
            "statusMessage": "P-033 — Verificando se sync e necessario..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -NonInteractive -File .claude/hooks/stop_checklist.ps1",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
