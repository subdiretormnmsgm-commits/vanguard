      "destinations": [
        { "pattern": "PENTALATERAL_UNIVERSAL/NOTEBOOKLM_BASE/04_INTELLIGENCE_LEDGER.md", "action": "copy_fixed" },
        { "pattern": "CLIENTES/*/NOTEBOOKLM_FONTES/04_INTELLIGENCE_LEDGER.md", "action": "copy_to_all_clients" },
        { "pattern": "CLIENTES/*/CLAUDE_PROJECT/06_INTELLIGENCE_LEDGER.md", "action": "copy_to_all_clients_claude_project" }
      ]
    },
    {
